; arithmetic
(define x 12)
(define y 5)

(define (distance x y)
  (sqrt (+ (expt x 2) (expt y 2))))

(distance x y)

(define prefix "hello")
(define suffix "world")

(define hello (string-append prefix "_" suffix))
(substring hello 1 3)
(substring hello 0)
(string-ith hello 4)
(define str "helloworld")
(define i 5)
(string-append (substring str 0 i) "_" (substring str i))
(define (str-remove str i)
     (string-append (substring str 0 i) (substring str (+ i 1))))
(str-remove str 1)

